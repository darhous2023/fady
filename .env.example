# ==== elfady — Environment Variables (example / placeholders only) ====
# انسخ هذا الملف إلى .env.local واملأ القيم الحقيقية. لا ترفع .env.local على GitHub.

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Supabase (client) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Supabase (server only) ---
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- Database (Drizzle / Postgres) ---
# Runtime (Vercel serverless): استخدم Transaction pooler (بورت 6543)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:6543/postgres
# Migrations: استخدم الاتصال المباشر (بورت 5432)
MIGRATION_DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# --- Better Auth ---
BETTER_AUTH_SECRET=generate_a_long_random_string
BETTER_AUTH_URL=https://your-app.vercel.app

# --- Cars Catalog (separate database, separate connection pool — never reuse DATABASE_URL) ---
# Transaction-mode pooler connection string for the isolated cars-catalog project.
CARS_DATABASE_URL=postgresql://postgres:PASSWORD@HOST:6543/postgres

# --- Optional: Analytics ---
NEXT_PUBLIC_GA_ID=

# --- Optional: Email notifications ---
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=

# --- Optional: rate limiting (Upstash Redis, free tier at upstash.com) ---
# Without these, rate limiting silently no-ops -- not required for the app to run.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional: error monitoring (Sentry, free tier at sentry.io) ---
# Without NEXT_PUBLIC_SENTRY_DSN, Sentry.init() no-ops -- not required for the app to run.
# SENTRY_AUTH_TOKEN/ORG/PROJECT are only needed for source-map upload at build time.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
